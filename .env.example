# =============================================================================
# fast-mcp-claude — peer-to-peer Claude Code remote control MCP server
# =============================================================================
# Copy this file to .env and customize. Each peer machine has its own .env.

# -----------------------------------------------------------------------------
# Local identity
# -----------------------------------------------------------------------------
# Friendly name for THIS machine (used as the `sender` field on outgoing
# messages so the remote knows who is talking).
PEER_NAME=workstation

# -----------------------------------------------------------------------------
# MCP server bind config
# -----------------------------------------------------------------------------
MCP_HOST=127.0.0.1
MCP_PORT=5473

# -----------------------------------------------------------------------------
# MCP endpoint authentication (REQUIRED for non-localhost deployments)
# -----------------------------------------------------------------------------
# Bearer token clients must send. Generate with: openssl rand -hex 32
# If unset, the endpoint is unauthenticated (only safe for 127.0.0.1).
# MCP_API_KEY=
# MCP_AUTH_ENABLED=true

# -----------------------------------------------------------------------------
# Peer registry — the OTHER machines this server can call out to
# -----------------------------------------------------------------------------
# JSON array. Each entry needs: name, url (full /mcp endpoint), api_key (the
# REMOTE peer's MCP_API_KEY). Example:
# PEERS=[{"name":"laptop","url":"https://laptop.example.ts.net:5473/mcp","api_key":"abc123..."}]
PEERS=[]

# -----------------------------------------------------------------------------
# File-bridge sandbox — directories the remote_read/write tools may touch
# -----------------------------------------------------------------------------
# Colon-separated list of absolute paths. Empty = file bridge disabled.
# Example: WORKSPACE_ROOTS=/Users/me/repos/projectA:/Users/me/repos/projectB
WORKSPACE_ROOTS=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# DB_PATH=~/.fast-mcp-claude/store.db
# Inbox/outbox TTL in seconds (cleaned up periodically). Default 7 days.
# STORE_TTL_SECONDS=604800

# -----------------------------------------------------------------------------
# Long-poll tuning
# -----------------------------------------------------------------------------
# Max seconds a single wait_for_instruction / subscribe call may block.
# Keep below Claude Code's MCP idle timeout (~30s for stdio, longer for http).
# POLL_MAX_WAIT_S=25
# Heartbeat interval — short waits return quickly with null so the worker
# loop keeps the MCP connection warm.
# POLL_HEARTBEAT_S=20

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=console   # or "json" for production aggregation
