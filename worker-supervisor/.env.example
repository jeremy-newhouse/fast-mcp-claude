# worker-supervisor configuration (all keys optional; defaults per
# evolv-coder-agent docs/architecture/worker-supervisor.md #configuration).
# Per-worker overrides at `workers spawn` win over these.

# --- limits ---
SUPERVISOR_MAX_WALL_CLOCK_S=1800          # hard per-turn wall clock (kill on breach)
SUPERVISOR_MAX_TURNS=50                   # SDK max_turns per query (runaway-agent stop)
SUPERVISOR_MAX_BUDGET_USD_PER_EPOCH=10    # notional-cost cap per epoch (usage-pressure guard)
SUPERVISOR_QUESTION_TIMEOUT_S=14400       # unanswered question ends the turn (4 h)
SUPERVISOR_CYCLE_CONTEXT_PCT=80           # auto-cycle trigger on context pressure
SUPERVISOR_MAX_CONCURRENT_TURNS=4         # cross-worker concurrency cap
SUPERVISOR_WORKER_IDLE_TIMEOUT_S=86400    # idle worker auto-retires (final handover write)
SUPERVISOR_MCP_STARTUP_GRACE_S=3          # head start before the prompt lands, MCP-granted lanes only (ECA-101)

# --- paths ---
# SUPERVISOR_HOME=~/.worker-supervisor    # state.db, event logs, capsules, control socket
# SUPERVISOR_SOCKET=                      # short socket path override (AF_UNIX ~104-byte cap)

# --- mesh presence (ADR-0028 Amendment A4: workers announce role="worker") ---
# Empty/unset = presence disabled (supervisor still fully functional).
# MESH_URL=http://127.0.0.1:5473/mcp
# MESH_API_KEY=<this peer's own bearer>
# SUPERVISOR_MACHINE=<peer name, e.g. mbpm2>
# SUPERVISOR_ANNOUNCE_INTERVAL_S=60

# NOTE: model auth is the host's logged-in Claude CLI subscription (ADR-0028 A3).
# Never put ANTHROPIC_API_KEY or AWS/Bedrock credentials here - worker env is
# allowlist-built and would not forward them anyway (AC-WS-9).
