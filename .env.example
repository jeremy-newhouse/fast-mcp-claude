# =============================================================================
# fast-mcp-claude — peer-to-peer Claude Code remote control MCP server
# =============================================================================
# Copy this file to .env and customize. Each peer machine has its own .env.

# -----------------------------------------------------------------------------
# Local identity
# -----------------------------------------------------------------------------
# Friendly name for THIS machine (used as the `sender` field on outgoing
# messages so the remote knows who is talking).
PEER_NAME=workstation

# -----------------------------------------------------------------------------
# MCP server bind config
# -----------------------------------------------------------------------------
MCP_HOST=127.0.0.1
MCP_PORT=5473

# -----------------------------------------------------------------------------
# MCP endpoint authentication (REQUIRED for non-localhost deployments)
# -----------------------------------------------------------------------------
# Bearer token clients must send. Generate with: openssl rand -hex 32
# MCP_AUTH_ENABLED defaults to true, which REQUIRES MCP_API_KEY -- the server
# refuses to start otherwise (fails closed rather than serving unauthenticated).
# For local-only, no-auth use on 127.0.0.1, explicitly set MCP_AUTH_ENABLED=false.
# MCP_API_KEY=
# MCP_AUTH_ENABLED=true

# Optional SECOND bearer, distinct from MCP_API_KEY, for a designated trusted hub/admin
# origin. Every peer in a mesh shares MCP_API_KEY, so it alone cannot prove a caller is a
# trusted hub rather than any other peer -- send_prompt only lets a caller's
# metadata.triggering_admin claim become true (channel.py's permission-relay admin
# fast-path) when the request authenticated with THIS key. Unset (default) means nobody is
# ever admin-trusted. Generate with: openssl rand -hex 32
# MCP_ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# Peer registry — the OTHER machines this server can call out to
# -----------------------------------------------------------------------------
# JSON array. Each entry needs: name, url (full /mcp endpoint), api_key (the
# REMOTE peer's MCP_API_KEY). Example:
# PEERS=[{"name":"laptop","url":"https://laptop.example.ts.net:5473/mcp","api_key":"abc123..."}]
PEERS=[]

# -----------------------------------------------------------------------------
# File-bridge sandbox — directories the remote_read/write tools may touch
# -----------------------------------------------------------------------------
# Colon-separated list of absolute paths. Empty = file bridge disabled.
# Example: WORKSPACE_ROOTS=/Users/me/repos/projectA:/Users/me/repos/projectB
WORKSPACE_ROOTS=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# DB_PATH=~/.fast-mcp-claude/store.db
# Inbox/outbox TTL in seconds (cleaned up periodically). Default 7 days.
# STORE_TTL_SECONDS=604800

# -----------------------------------------------------------------------------
# Long-poll tuning
# -----------------------------------------------------------------------------
# Max seconds a single wait_for_instruction / subscribe call may block.
# Keep below Claude Code's MCP idle timeout (~30s for stdio, longer for http).
# POLL_MAX_WAIT_S=25
# Heartbeat interval — short waits return quickly with null so the worker
# loop keeps the MCP connection warm.
# POLL_HEARTBEAT_S=20

# -----------------------------------------------------------------------------
# Channel adapter (fast-mcp-claude-channel) — push mode, STRICT opt-in
# -----------------------------------------------------------------------------
# OFF by default. Leaving it off means a `claude-channel` entry wired into
# .mcp.json stays inert (it completes the MCP handshake but never polls, claims,
# or pushes inbox messages) — so it coexists safely with /worker loop mode and
# never eats messages. Set true to arm the push bridge. NOTE: arming the channel
# also requires launching the worker with
#   claude --dangerously-load-development-channels server:claude-channel
# Do NOT double-arm one worker (channel adapter AND /worker for the same identity).
# CHANNEL_ENABLED=false
# Adapter identity / presence mailbox. Defaults to PEER_NAME. This is the value a
# controller addresses via send_prompt(recipient_session="<identity>").
# CHANNEL_IDENTITY=
# One-line presence blurb other peers see via who().
# CHANNEL_SUMMARY=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=console   # or "json" for production aggregation
